# Local Ollama endpoint (Required for privacy/local models)
OLLAMA_API_BASE=http://host.docker.internal:11434

# Firecrawl API Key (Optional, used by MCP Scraper for premium markdown)
FIRECRAWL_API_KEY=your_key_here

# Gemini API Key (Optional, if switching model source away from local)
GEMINI_API_KEY=your_key_here
